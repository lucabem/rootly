#!/usr/bin/env bash
# Appends an entry to CHANGELOG.md after each commit.
# Does NOT stage the file — commit it manually when ready.
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/.." && pwd)"

if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    ENV_FILE="$PROJECT_ROOT/.env"
    [ -f "$ENV_FILE" ] && set -a && source "$ENV_FILE" && set +a
fi

python3 "$HOOK_DIR/update_changelog.py" "$PROJECT_ROOT"

# Usuario del host — evita que Docker cree ficheros owned por root
# Ejecuta: echo "UID=$(id -u)" >> .env && echo "GID=$(id -g)" >> .env
UID=1000
GID=1000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# AWS (puede ser IAM estático o credenciales temporales de STS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-west-1

# S3 - bucket y prefijos donde viven los eventos OpenLineage y el código Glue
S3_BUCKET=your-bucket-name
S3_EVENTS_PREFIX=openlineage/
S3_JOBS_PREFIX=glue/code/jobs/

# Redis (usado por Celery en el backend)
REDIS_URL=redis://localhost:6379/0
